# ============================================================
# AI STYLIST BACKEND — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in all values
# NEVER commit .env to git
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# Firebase Admin SDK
# Option A (local dev): leave this empty — reads from ../credits/serviceAccountKey.json
# Option B (Render / production): paste the full JSON string of serviceAccountKey.json here
FIREBASE_SERVICE_ACCOUNT=

# Ximilar
# Get from: https://app.ximilar.com → API → Authorization Token
XIMILAR_API_TOKEN=your_ximilar_token_here

# Google Gemini
# Get from: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here

# RevenueCat
# Get from: https://app.revenuecat.com → Project → API Keys → Webhook shared secret
REVENUECAT_WEBHOOK_SECRET=your_revenuecat_webhook_secret_here

# App Deep Link scheme (must match your Expo app.json scheme)
APP_DEEP_LINK=aistylist
