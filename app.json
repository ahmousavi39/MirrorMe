{
  "expo": {
    "name": "MirrorMe",
    "slug": "MirrorMe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "mirrorme",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#B033B5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ahmousavi.mirrorme",
      "googleServicesFile": "./credits/GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "MirrorMe needs camera access to capture your outfit for style analysis.",
        "NSPhotoLibraryUsageDescription": "MirrorMe needs photo library access to select your outfit for style analysis.",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.511134609232-l6ufeq2gnunaqp2j32kt7p8duop9ffd2"
            ]
          }
        ]
      },
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#B033B5"
      },
      "package": "com.ahmousavi.MirrorMe",
      "googleServicesFile": "./credits/google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "MirrorMe needs photo access to analyze your outfit.",
          "cameraPermission": "MirrorMe needs camera access to capture your outfit."
        }
      ],
      "expo-asset",
      "expo-apple-authentication",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "30856d60-3f87-40c9-babb-e226d5bfedde"
      }
    }
  }
}
